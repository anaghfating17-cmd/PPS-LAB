st = int(input())
stop = int(input())
found = False
for n in range(st, stop+1):
    if n > 1:
        prime = True
        for i in range(2, int(n**0.5) + 1):
            if n % i == 0:
                prime = False
                break
        if prime:
            print(n)
            found = True
if not found:
    print("No primes")
